# ──────────────────────────────────────────────────────────────────────────────
# Required to run the web app
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic API key used by /api/audit, /api/extract-line-items, /api/generate-letter.
ANTHROPIC_API_KEY=

# Supabase project URL and anon key. Both are exposed to the browser bundle via
# the NEXT_PUBLIC_ prefix — this is expected; the anon key is safe to expose
# when Row Level Security is configured on every user-scoped table.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Payments — Stripe (required for Single Dispute + Membership checkout/webhook)
# ──────────────────────────────────────────────────────────────────────────────

# Stripe secret key (sk_test_… in test mode, sk_live_… in production).
STRIPE_SECRET_KEY=
# Signing secret for the /api/webhooks/stripe endpoint (whsec_…). Use the value
# from the Stripe Dashboard webhook endpoint (or `stripe listen` locally).
STRIPE_WEBHOOK_SECRET=
# Price IDs (price_…) for each plan.
STRIPE_PRICE_SINGLE_DISPUTE=
# "Dispute Package + Certified Mail" $59 one-time price id. Its purchase also
# unlocks the mail-it-for-me (Lob) fulfillment for that case.
STRIPE_PRICE_DISPUTE_CERTIFIED=
STRIPE_PRICE_MEMBERSHIP_MONTHLY=
STRIPE_PRICE_MEMBERSHIP_ANNUAL=
# Origin used to build Checkout success/cancel URLs. Falls back to the request
# origin when unset; set it explicitly on Vercel.
NEXT_PUBLIC_SITE_URL=

# Bearer token for the Vercel cron routes (/api/cron/deadlines,
# /api/cron/recompute-storm-index). Any strong random string; without it every
# cron request is rejected with 401.
CRON_SECRET=

# Comma-separated list of valid beta promo codes that comp the dispute package
# (same effect as a paid Single Dispute). Rotate freely — no code change needed.
# Example: BETA_PROMO_CODES="BETA2026, PRESS, FAMILY"
BETA_PROMO_CODES=

# ──────────────────────────────────────────────────────────────────────────────
# Site-wide password gate (free replacement for Vercel Password Protection)
# ──────────────────────────────────────────────────────────────────────────────

# When set, the whole site is gated behind a single shared password (src/middleware.ts
# rewrites unauthenticated visitors to /gate). The cookie stores only a hash of
# this value, never the raw password. Stripe webhooks, Next internals, and the
# gate itself stay reachable. To OPEN the site at launch, simply unset this var —
# the middleware then passes everyone through.
SITE_ACCESS_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# Optional — error monitoring
# ──────────────────────────────────────────────────────────────────────────────

# Sentry DSN. Same value goes in both server and client variables. When either
# is unset, Sentry initialization is skipped silently. Both must be set to
# capture both server-side API errors and browser-side crashes.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog product analytics. Unset → every capture is a silent no-op (client
# and server). The project API key is public by design (NEXT_PUBLIC_ is safe);
# the host defaults to https://us.i.posthog.com when unset. Used server-side
# too (src/lib/analytics-server.ts reads the same variables).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Transactional email (Resend). Both must be set or every send is a no-op and
# /api/email-report returns 503. EMAIL_FROM needs a Resend-verified domain,
# e.g. "Verity <reports@verity.example>". Server-only — no NEXT_PUBLIC_.
RESEND_API_KEY=
EMAIL_FROM=

# ──────────────────────────────────────────────────────────────────────────────
# Required only for scripts/import-cms-data.ts (CMS reference data ingestion).
# Do NOT set these on the web app service.
# ──────────────────────────────────────────────────────────────────────────────

# Service-role key for privileged upserts into pfs_fee_schedule, clfs_fee_schedule,
# ncci_ptp_edits, ncci_mue_edits. Bypasses RLS — keep it server-side only and
# never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional overrides for CMS source URLs / paths. Defaults point at CMS index
# pages and must be overridden with the current-cycle download URL or local file.
# See README-DATA-SETUP.md for where to find each.
# PFS_SOURCE=
# CLFS_SOURCE=
# NCCI_PTP_SOURCE=
# NCCI_MUE_SOURCE=

# CMS conversion factor used to derive PFS dollar amounts from RVUs when the
# source file only provides RVUs. Default: 32.7442 (CMS 2024 final rule).
# PFS_CONVERSION_FACTOR=32.7442
